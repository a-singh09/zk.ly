{
  "name": "hello-world-compact",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "compact compile contracts/hello-world.compact contracts/managed/hello-world",
    "build": "tsc",
    "deploy": "tsx src/deploy.ts",
